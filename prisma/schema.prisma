generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// TODO: Definir vos modeles ici
// Suivez le guide GUIDE.md pour l'implementation complete

model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  password    String
  name        String
  role        Role     @default(USER)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // TODO: Ajouter les relations
  // events  Event[]
  // tickets Ticket[]

  @@map("users")
}

model event {
  id          Int     @id @default(autoincrement())
  title       String
  date        DateTime
  place       String
  price       Decimal
  totalPlaces Int
  category    EventCategory
  image      String?
}

// TODO: Ajouter le modele Event
// TODO: Ajouter le modele Ticket

enum Role {
  USER
  ORGANIZER
  ADMIN
}

enum EventCategory {
  CONCERT
  CONFERENCE
  FESTIVAL
  SPORT
  THEATRE
  AUTRE
}
// TODO: Ajouter les autres enums (Category, TicketStatus)
