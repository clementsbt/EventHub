generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// TODO: Definir vos modeles ici
// Suivez le guide GUIDE.md pour l'implementation complete

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // TODO: Ajouter les relations
  // events  Event[]
  // tickets Ticket[]

  @@map("users")
}

// TODO: Ajouter le modele Event
// TODO: Ajouter le modele Ticket

enum Role {
  USER
  ORGANIZER
  ADMIN
}

